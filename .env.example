# Application configuration (Example)
VITE_APP_ID=tradequote-uk
OAUTH_SERVER_URL=https://auth.manus.im
OWNER_OPEN_ID=mock-user-id
NODE_ENV=development

# Database Configuration
# Format: mysql://user:password@host:port/database?ssl={"rejectUnauthorized":true}
DATABASE_URL=mysql://user:password@host:port/database?ssl={"rejectUnauthorized":true}

# JWT Secret (Must be a long random string)
JWT_SECRET=your-secret-key-here

# Preview URLs (Update with your public domain)
EXPO_WEB_PREVIEW_URL=
EXPO_PACKAGER_PROXY_URL=
